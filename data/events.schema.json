{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Iran-Israel Conflict Events",
  "description": "冲突事件数据结构",
  "type": "object",
  "properties": {
    "metadata": {
      "type": "object",
      "properties": {
        "last_updated": {
          "type": "string",
          "format": "date-time"
        },
        "total_events": {
          "type": "integer"
        },
        "conflict_start": {
          "type": "string",
          "format": "date"
        }
      }
    },
    "stats": {
      "type": "object",
      "properties": {
        "duration_days": {
          "type": "integer"
        },
        "missiles_launched": {
          "type": "string"
        },
        "drone_attacks": {
          "type": "string"
        },
        "civilian_deaths": {
          "type": "string"
        }
      }
    },
    "events": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "date": {
            "type": "string",
            "format": "date"
          },
          "time": {
            "type": "string"
          },
          "title": {
            "type": "string"
          },
          "details": {
            "type": "string"
          },
          "tags": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "critical": {
            "type": "boolean"
          },
          "sources": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "name": {
                  "type": "string"
                },
                "url": {
                  "type": "string",
                  "format": "uri"
                }
              }
            }
          }
        }
      }
    }
  }
}
